# This file can be copied to the file named '.env' in this directory
# and these values will override the system environment variables
# via the python-dotenv library.
# CAIG_GRAPH_SOURCE_TYPE should be "rdf_file" or "cosmos_nosql" or ""
# CAIG_GRAPH_SOURCE_OWL_FILENAME and CAIG_GRAPH_NAMESPACE should be set to "" if graph is not used

CAIG_LOG_LEVEL="info"

# RBAC / Entra ID is always attempted first.
# CAIG_AZURE_OPENAI_KEY is only used as fallback when Entra auth is unavailable.
# CAIG_AZURE_OPENAI_KEY="<YOUR_AZURE_OPENAI_KEY_HERE>"
CAIG_AZURE_OPENAI_URL="<YOUR_AZURE_OPENAI_ENDPOINT_HERE>"

CAIG_AZURE_OPENAI_COMPLETIONS_DEP="gpt-5.1-codex-mini"
CAIG_AZURE_OPENAI_VERSION="2025-01-01-preview"

CAIG_GRAPH_SOURCE_DB="caig"
CAIG_CONVERSATIONS_CONTAINER="conversations"
CAIG_COSMOSDB_NOSQL_URI="<YOUR_COSMOSDB_NOSQL_URI_HERE>"
# CAIG_COSMOSDB_NOSQL_KEY is only used as fallback when Entra auth is unavailable.
CAIG_COSMOSDB_NOSQL_KEY="<YOUR_COSMOSDB_NOSQL_KEY_HERE>"

#CAIG_STRATEGY_BYPASS="true"
CAIG_WAIT_FOR_DEBUGGER="true"

############### Libraries (database)
CAIG_GRAPH_SOURCE_CONTAINER="libraries"
CAIG_GRAPH_SOURCE_OWL_FILENAME="ontologies/libraries.owl"
CAIG_GRAPH_SOURCE_TYPE="cosmos_nosql"
CAIG_GRAPH_NAMESPACE="http://cosmosdb.com/caig#"
CAIG_DATA_SOURCE_DIR="../../data/pypi/wrangled_libs"
CAIG_GRAPH_SOURCE_PK="pk"
CAIG_AZURE_OPENAI_EMBEDDINGS_DEP="text-embedding-3-small"
CAIG_FULLTEXT_SEARCH_FIELDS="description,summary,documentation_summary,keywords"